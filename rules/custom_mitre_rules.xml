


<group name="windows, cyber_security, capstone_fyep">

  <rule id="100001" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine">-encodedcommand|-enc|-e </field>
    <description>CyberSecurity Alert: T1059.001 - Suspicious PowerShell Obfuscation via EncodedCommand Detected</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>

  <rule id="100002" level="13">
    <if_group>windows</if_group>
    <field name="win.eventdata.targetImage">lsass.exe</field>
    <field name="win.eventdata.sourceImage">!svchost.exe</field>
    <field name="win.eventdata.sourceImage">!wininit.exe</field>
    <field name="win.eventdata.sourceImage">!csrss.exe</field>
    <description>CRITICAL Alert: T1003 - Unauthorized Access to LSASS Memory (Potential Credential Dumping via Mimikatz)</description>
    <mitre>
      <id>T1003</id>
    </mitre>
  </rule>

  <rule id="100003" level="5">
    <if_group>windows</if_group>
    <field name="win.system.eventID">4625</field>
    <description>Windows: Failed Authentication Attempt</description>
  </rule>

  <rule id="100004" level="11" frequency="10" timeframe="120">
    <if_matched_sid>100003</if_matched_sid>
    <description>CyberSecurity Alert: T1021 - Multiple Failed RDP/SMB Logins (Brute Force Detection)</description>
    <mitre>
      <id>T1021</id>
    </mitre>
  </rule>

<!-- Login dini hari sebelum jam kerja -->
<rule id="100005" level="10">
  <if_group>windows</if_group>
  <field name="win.eventdata.targetUserName">^Administrator$|admin</field>
  <field name="win.eventdata.targetUserName">!fyep-2</field>
  <time>00:00 - 08:59</time>
  <description>Suspicious Admin Login - Outside Business Hours (Before Work): User $(win.eventdata.targetUserName) from $(win.eventdata.ipAddress) - Inspired by MGM Resorts 2023 breach - MITRE T1078</description>
  <mitre>
    <id>T1078</id>
  </mitre>
</rule>

<!-- Login malam setelah jam kerja -->
<rule id="100006" level="10">
  <if_group>windows</if_group>
  <field name="win.eventdata.targetUserName">^Administrator$|admin</field>
  <field name="win.eventdata.targetUserName">!fyep-2</field>
  <time>17:01 - 23:59</time>
  <description>Suspicious Admin Login - Outside Business Hours (After Work): User $(win.eventdata.targetUserName) from $(win.eventdata.ipAddress) - Inspired by MGM Resorts 2023 breach - MITRE T1078</description>
  <mitre>
    <id>T1078</id>
  </mitre>
</rule>

<!-- SSH Linux dini hari -->
<rule id="100009" level="10">
  <if_sid>5715</if_sid>
  <time>00:00 - 08:59</time>
  <description>Suspicious Admin Login - Outside Business Hours (Before Work): SSH login by $(dstuser) from $(srcip) - Inspired by MGM Resorts 2023 breach - MITRE T1078</description>
  <mitre>
    <id>T1078</id>
  </mitre>
</rule>

<!-- SSH Linux malam -->
<rule id="100011" level="10">
  <if_sid>5715</if_sid>
  <time>17:01 - 23:59</time>
  <description>Suspicious Admin Login - Outside Business Hours (After Work): SSH login by $(dstuser) from $(srcip) - Inspired by MGM Resorts 2023 breach - MITRE T1078</description>
  <mitre>
    <id>T1078</id>
  </mitre>
</rule>

<!-- Eskalasi multiple login -->
<rule id="100010" level="12" frequency="3" timeframe="300">
  <if_matched_sid>100009</if_matched_sid>
  <description>Suspicious Admin Login - Multiple logins outside business hours - Possible Account Compromise - MGM T1078</description>
  <mitre>
    <id>T1078</id>
  </mitre>
</rule>

<!-- SSH brute force detection -->
<rule id="100012" level="11" frequency="10" timeframe="120">
  <if_matched_sid>5710</if_matched_sid>
  <same_source_ip/>
  <description>CyberSecurity Alert: T1110 - SSH Brute Force detected from $(srcip)</description>
  <mitre>
    <id>T1110</id>
  </mitre>
</rule>

</group>
