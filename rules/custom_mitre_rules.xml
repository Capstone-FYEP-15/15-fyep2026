<group name="windows, cyber_security, capstone_fyep">

  <rule id="100001" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.commandLine">-encodedcommand|-enc|-e </field>
    <description>CyberSecurity Alert: T1059.001 - Suspicious PowerShell Obfuscation via EncodedCommand Detected</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>

  <rule id="100002" level="13">
    <if_group>windows</if_group>
    <field name="win.eventdata.targetImage">lsass.exe</field>
    <field name="win.eventdata.sourceImage">!svchost.exe</field>
    <field name="win.eventdata.sourceImage">!wininit.exe</field>
    <field name="win.eventdata.sourceImage">!csrss.exe</field>
    <description>CRITICAL Alert: T1003 - Unauthorized Access to LSASS Memory (Potential Credential Dumping via Mimikatz)</description>
    <mitre>
      <id>T1003</id>
    </mitre>
  </rule>

  <rule id="100003" level="5">
    <if_group>windows</if_group>
    <field name="win.system.eventID">4625</field>
    <description>Windows: Failed Authentication Attempt</description>
  </rule>

  <rule id="100004" level="11" frequency="10" timeframe="120">
    <if_matched_sid>100003</if_matched_sid>
    <description>CyberSecurity Alert: T1021 - Multiple Failed RDP/SMB Logins (Brute Force Detection)</description>
    <mitre>
      <id>T1021</id>
    </mitre>
  </rule>

  <rule id="100005" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.targetUserName">^Administrator$|admin</field>
    <field name="win.eventdata.targetUserName">!fyep-2</field> 
    <time>22:00 - 23:59</time>
    <description>CyberSecurity Alert: T1078 - Privileged Account Login Outside Working Hours (Late Night)</description>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

  <rule id="100006" level="10">
    <if_group>windows</if_group>
    <field name="win.eventdata.targetUserName">^Administrator$|admin</field>
    <field name="win.eventdata.targetUserName">!fyep-2</field> 
    <time>00:00 - 06:00</time>
    <description>CyberSecurity Alert: T1078 - Privileged Account Login Outside Working Hours (Early Morning)</description>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

</group>