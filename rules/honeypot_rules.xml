<group name="honeypot,">

  <!-- Koneksi baru ke honeypot SSH (Cowrie) -->
  <rule id="100100" level="12">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.session.connect</field>
    <description>HONEYPOT TRIGGERED - New SSH connection to honeypot from $(src_ip)</description>
    <group>honeypot,canary_trap,</group>
    <mitre>
      <id>T1046</id>
      <id>T1021</id>
    </mitre>
  </rule>

  <!-- Login berhasil ke honeypot -->
  <rule id="100101" level="14">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.login.success</field>
    <description>HONEYPOT TRIGGERED - Attacker logged into honeypot (user: $(username) pass: $(password))</description>
    <group>honeypot,canary_trap,intrusion_detected,</group>
    <mitre>
      <id>T1078</id>
      <id>T1021</id>
    </mitre>
  </rule>

  <!-- Login gagal ke honeypot -->
  <rule id="100102" level="10">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.login.failed</field>
    <description>HONEYPOT TRIGGERED - Failed login attempt to honeypot (user: $(username))</description>
    <group>honeypot,canary_trap,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Command dijalankan di dalam honeypot -->
  <rule id="100103" level="12">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.command.input</field>
    <description>HONEYPOT TRIGGERED - Command executed in honeypot: $(input)</description>
    <group>honeypot,canary_trap,</group>
    <mitre>
      <id>T1059</id>
    </mitre>
  </rule>

  <!-- Download file dari honeypot -->
  <rule id="100104" level="15">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.session.file_download</field>
    <description>HONEYPOT TRIGGERED - CRITICAL: File download attempt in honeypot by $(src_ip)</description>
    <group>honeypot,canary_trap,data_exfiltration,</group>
    <mitre>
      <id>T1005</id>
      <id>T1041</id>
    </mitre>
  </rule>

</group>
