<!-- ============================================================
     Log4Shell Detection Rules
     CVE-2021-44228 | MITRE T1190 — Exploit Public-Facing Application

     Reference: https://github.com/advisories/GHSA-jfh8-c2jp-5v3q
     ============================================================ -->

<group name="log4shell,web,attack,">

  <!-- CVE-2021-44228 | MITRE T1190 — Exploit Public-Facing Application -->
  <!-- Reference: https://github.com/advisories/GHSA-jfh8-c2jp-5v3q -->

  <!-- Rule 1: Deteksi JNDI payload di HTTP request -->
  <rule id="100800" level="13">
    <if_group>web|apache|nginx</if_group>
    <match>jndi:</match>
    <description>Log4Shell Exploitation Attempt - CVE-2021-44228: JNDI injection in HTTP request from $(srcip)</description>
    <group>log4shell,exploit,cve_2021_44228,</group>
    <mitre>
      <id>T1190</id>
      <id>T1059</id>
    </mitre>
  </rule>

  <!-- Rule 2: Deteksi variasi protocol JNDI -->
  <rule id="100801" level="13">
    <if_group>web|apache|nginx</if_group>
    <match>jndi:ldap|jndi:rmi|jndi:dns|jndi:iiop</match>
    <description>Log4Shell Protocol Attempt - CVE-2021-44228: JNDI protocol payload from $(srcip)</description>
    <group>log4shell,exploit,cve_2021_44228,</group>
    <mitre>
      <id>T1190</id>
      <id>T1027</id>
    </mitre>
  </rule>

  <!-- Rule 3: Eskalasi multiple attempts -->
  <rule id="100802" level="15" frequency="3" timeframe="60">
    <if_matched_sid>100800</if_matched_sid>
    <description>Log4Shell Exploitation Attempt - CVE-2021-44228: Multiple JNDI injection attempts from $(srcip)</description>
    <group>log4shell,exploit,cve_2021_44228,critical,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- Rule 4: Fallback match di semua log -->
  <rule id="100803" level="13">
    <match>jndi:ldap://</match>
    <description>Log4Shell Exploitation Attempt - CVE-2021-44228: JNDI LDAP payload detected</description>
    <group>log4shell,exploit,cve_2021_44228,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

</group>
